# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/remotion"

# Redis (BullMQ queue)
REDIS_URL="redis://localhost:6379"

# Remotion Lambda
REMOTION_AWS_ACCESS_KEY_ID=your_key
REMOTION_AWS_SECRET_ACCESS_KEY=your_secret
REMOTION_AWS_REGION=us-east-1
REMOTION_SERVE_URL=https://your-site.s3.amazonaws.com/index.html
REMOTION_FUNCTION_NAME=remotion-render-fn

# Webhook security
WEBHOOK_SECRET=change-me-in-production
ADMIN_SECRET=change-me-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Per-checkout HMAC (prevents replay attacks on Stripe webhooks)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHECKOUT_HMAC_SECRET=change-me-generate-random-64-char-hex

# Analytics tracking token (for /api/analytics/track endpoint)
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ANALYTICS_TOKEN=change-me-generate-random-hex

# SSRF protection — comma-separated list of allowed callback domains
# Leave empty to allow all valid HTTPS domains (not recommended for production)
ALLOWED_CALLBACK_DOMAINS=your-domain.com,api.your-domain.com

# Worker config
WORKER_CONCURRENCY=5
